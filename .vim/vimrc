"
" Plugins
"

call plug#begin('~/.vim/plugged')
Plug 'tpope/vim-commentary'
Plug 'tpope/vim-fugitive'
Plug 'sheerun/vim-polyglot'
Plug 'ctrlpvim/ctrlp.vim'
Plug 'romainl/Apprentice'
Plug 'neoclide/coc.nvim', {'branch': 'release'}
call plug#end()

"
" Make leader = space
"

nnoremap <SPACE> <Nop>
let mapleader=" "

"
" Set theme
"

colorscheme apprentice

"
" Enable syntax highlighting + filetype detection
"

syntax on
filetype plugin indent on

"
" Coc.nvim config
"

set encoding=utf-8
set hidden
set updatetime=300
nmap <leader>rn <Plug>(coc-rename)
nmap <silent>gd <Plug>(coc-definition)
nmap <silent>gr <Plug>(coc-references)
nmap <silent>gi <Plug>(coc-implementation)
nmap <silent> <C-s> <Plug>(coc-range-select)
xmap <silent> <C-s> <Plug>(coc-range-select)
nnoremap <silent>K :call <SID>show_documentation()<CR>
inoremap <silent><expr> <cr> pumvisible() ? coc#_select_confirm()
    \: "\<C-g>u\<CR>\<c-r>=coc#on_enter()\<CR>"

"
" Functions
"

function! s:show_documentation()
    if (index(['vim', 'help'], &filetype) >= 0)
        execute 'h ' . expand('<cword>')
    elseif (coc#rpc#ready())
        call CocActionAsync('doHover')
    else
        execute '!' . &keywordprg . ' ' . expand('<cword>')
    endif
endfunction

"
" Fugitive config
"

nnoremap <leader>gg :Ggrep!

"
" CtrlP config
"

nnoremap <leader>p :CtrlP<CR>
let g:ctrlp_custom_ignore='\v[\/](node_modules|target|dist)|(\.(swp|ico|git|svn))$'
let g:ctrlp_prompt_mappings={
    \ 'AcceptSelection("e")': ['<2-LeftMouse>'],
    \ 'AcceptSelection("t")': ['<cr>'],
    \ }

"
" More ergonomic window switching
"

nnoremap <leader>a <C-W>w

"
" File tree config
"

nnoremap <leader>t :Lex<CR>
let g:netrw_liststyle=3
let g:netrw_list_hide='.*\.swp$'

"
" Search settings
"

set incsearch
set ignorecase

"
" Misc. settings
"

set cursorline
set tabstop=4 softtabstop=4
set shiftwidth=4
set expandtab
set smartindent
set scrolloff=8
set number
set relativenumber
set mouse=a
set nocompatible
set modelines=0
set autoread
set backspace=indent,eol,start
set noerrorbells
set nowrap

"
" Auto strip trailing whitespace
"

autocmd BufRead,BufWrite * if ! &bin | silent! %s/\s\+$//ge | silent! %s/\n\{3,}/\r\r/e | endif

"
" Spellcheck
"

autocmd FileType gitcommit setlocal spell spelllang=en_us
autocmd BufRead,BufNewFile *.md setlocal spell spelllang=en_us
autocmd BufRead,BufNewFile *.txt setlocal spell spelllang=en_us

"
" YAML overrides
"

autocmd FileType yaml
    \ setlocal
    \ ts=2
    \ sts=2
    \ sw=2
