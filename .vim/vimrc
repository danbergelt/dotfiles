"
" Fetch hard dependencies
"

func! Fetch(upstream, dest)
  if empty(glob(a:dest))
    silent execute '!curl -fLo ' . a:dest . ' --create-dirs ' . a:upstream
  endif
endfunc


"
" Fetch + set theme
"

call Fetch('https://raw.githubusercontent.com/romainl/Apprentice/master/colors/apprentice.vim', '~/.vim/colors/apprentice.vim')
colorscheme apprentice

"
" Fetch plugin manager
"

call Fetch('https://raw.githubusercontent.com/junegunn/vim-plug/master/plug.vim', '~/.vim/autoload/plug.vim')

"
" Plugins
"

call plug#begin('~/.vim/plugged')
Plug 'yuezk/vim-js'
Plug 'maxmellon/vim-jsx-pretty'
Plug 'vim-airline/vim-airline'
Plug 'vim-airline/vim-airline-themes'
call plug#end()

"
" Enable syntax highlighting + filetype detection
"

syntax on
filetype plugin indent on

"
" Airline config
"

let g:airline_theme='apprentice'
let g:airline_section_b='%F'
let g:airline_section_c=''
let g:airline_section_x=''
let g:airline_section_y='%Y'

"
" Search settings
"

set hlsearch
set incsearch
set ignorecase

"
" Misc. settings
"

set cursorline
set scrolloff=3
set expandtab
set backspace=indent,eol,start
set number
set mouse=a
set nocompatible
set modelines=0
set autoread

"
" Remove trailing whitespace on save
"

autocmd! BufWrite * mark ' | silent! %s/\s\+$// | norm ''

"
" Spellcheck
"

autocmd BufRead,BufNewFile *.md setlocal spell spelllang=en_us
autocmd BufRead,BufNewFile *.txt setlocal spell spelllang=en_us
autocmd FileType gitcommit setlocal spell spelllang=en_us

"
" YAML overrides
"

autocmd FileType yaml
  \ setlocal
  \ ts=2
  \ sts=2
  \ sw=2
