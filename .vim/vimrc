" fetch hard dependencies
func! Fetch(src, dest)
  if empty(glob(dest))
    silent execute '!curl -fLo ' . dest . ' --create-dirs ' . src
    autocmd VimEnter * PlugInstall --sync | source $MYVIMRC
  endif
endfunc


Fetch('~/.vim/colors/apprentice.vim', 'https://raw.githubusercontent.com/romainl/Apprentice/master/colors/apprentice.vim')
colorscheme apprentice


Fetch('~/.vim/autoload/plug.vim', 'https://raw.githubusercontent.com/junegunn/vim-plug/master/plug.vim')
call plug#begin('~/.vim/plugged')
Plug 'yuezk/vim-js'
Plug 'maxmellon/vim-jsx-pretty'
call plug#end()


syntax on
filetype plugin indent on


set hlsearch
set incsearch
set ignorecase
set gdefault


set cursorline
set title
set showcmd
set scrolloff=3
set expandtab
set backspace=indent,eol,start
set number
set mouse=a


autocmd FileType yaml
  \ setlocal
  \ ts=2
  \ sts=2
  \ sw=2
