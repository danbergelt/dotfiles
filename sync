set -e

echo "Syncing..."

# System dependencies
declare -a deps=(
    "rg"
    "fzf"
    "git"
    "vim"
    "tsc"
    "node"
    "tmux"
    "python3"
)

# Python dependencies
declare -a pydeps=(
    "flake8"
    "bandit"
    "pyright"
    "pyright-langserver"
)

# Node dependencies
declare -a jsdeps=(
    "eslint"
    "typescript"
    "typescript-language-server"
)

# Check all dependencies are installed
has_deps=true

missing() {
    has_deps=false
    echo "ERROR: missing $2 dependency $1"
}

for dep in "${deps[@]}"; do
    if [ -z `which $dep` ]; then
        missing $dep "system"
    elif [ $dep = "python3" ]; then
        installed=`python3 -m pip freeze`
        for pydep in "${pydeps[@]}"; do
            if [ -z `echo "$installed" | grep "^$pydep=="` ]; then
                missing $pydep "python3"
            fi
        done
    elif [ $dep = "node" ]; then
        installed=`npm list -g --depth=0 --parseable`
        for jsdep in "${jsdeps[@]}"; do
            if [ -z `echo "$installed" | grep "$jsdep$"` ]; then
                missing $jsdep "node"
            fi
        done
    fi
done

if [ $has_deps = false ]; then
    echo "Exiting..."; exit 1
fi

# Bootstrap dirs
mkdir -p ~/me
mkdir -p ~/.config/tmux

# Get dotfiles
url="https://raw.githubusercontent.com/danbergelt/dotfiles/main"
curl -s "$url/.bash_profile" > ~/.bash_profile
curl -s "$url/.vim/vimrc" > ~/.vim/vimrc
curl -s "$url/.config/tmux/tmux.conf" > ~/.config/tmux/tmux.conf
curl -s "$url/tsconfig.json" > ~/tsconfig.json
curl -s "$url/.eslintrc.json" > ~/.eslintrc.json

# Bootstrap vim
curl -sfLo ~/.vim/autoload/plug.vim --create-dirs \
    https://raw.githubusercontent.com/junegunn/vim-plug/master/plug.vim
vim -N -E -s -u "~/.vim/vimrc" +PlugInstall +qall
