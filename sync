set -e

echo "Syncing..."

# All dotfiles
declare -a files=(
    ".vimrc"
    ".tmux.conf"
    ".bash_profile"
    "jsconfig.json"
    ".eslintrc.json"
)

# System dependencies
declare -a deps=(
    "rg"
    "fzf"
    "git"
    "vim"
    "tsc"
    "node"
    "tmux"
    "python3"
)

# Python dependencies
declare -a pydeps=(
    "flake8"
    "bandit"
    "pyright"
)

# Node dependencies
declare -a jsdeps=(
    "eslint"
    "typescript"
    "typescript-language-server"
)

# Check all dependencies are installed
has_deps=true

missing() {
    has_deps=false
    echo "ERROR: missing $2 dependency $1"
}

for dep in "${deps[@]}"; do
    if [ -z `which $dep` ]; then
        missing $dep "system"

    elif [ $dep = "python3" ]; then
        installed=`python3 -m pip freeze`
        for pydep in "${pydeps[@]}"; do
            if [ -z `echo "$installed" | grep "^$pydep=="` ]; then
                missing $pydep "python3"
            fi
        done

    elif [ $dep = "node" ]; then
        installed=`npm list -g --depth=0 --parseable`
        for jsdep in "${jsdeps[@]}"; do
            if [ -z `echo "$installed" | grep "$jsdep$"` ]; then
                missing $jsdep "node"
            fi
        done
    fi
done

if [ $has_deps = false ]; then
    echo "Exiting..."; exit 1
fi

# Bootstrap workdir
mkdir -p ~/me

# Fetch dotfiles
url="https://raw.githubusercontent.com/danbergelt/dotfiles/main"
for df in "${files[@]}"; do
    curl -s $url/src/$df -o ~/$df
done

# Bootstrap vim
curl -sfLo ~/.vim/autoload/plug.vim --create-dirs \
    https://raw.githubusercontent.com/junegunn/vim-plug/master/plug.vim
vim -N -E -s -u "~/.vimrc" +PlugInstall +qall
