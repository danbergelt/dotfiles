set -e

# System dependencies
declare -a deps=(
    "fzf"
    "node"
    "git"
    "docker"
    "tmux"
    "ctags"
    "vim"
    "tsc"
    "rg"
    "python3"
)

# Python dependencies
declare -a pydeps=(
    "mypy"
    "pylsp-mypy"
    "pydocstyle"
    "pyflakes"
    "rope"
    "yapf"
    "python-lsp-server"
)

# Check all dependencies are installed
has_deps=true

missing() {
    has_deps=false
    echo "ERROR: $2 dependency $1 is not installed or is not in PATH"
}

for dep in "${deps[@]}"; do
    if [ -z `which $dep` ]; then
        missing $dep "system"
    fi

    if [ $dep = "python3" ]; then
        for pydep in "${pydeps[@]}"; do
            if [ -z `python3 -m pip freeze | grep "^$pydep=="` ]; then
                missing $pydep "python3"
            fi
        done
    fi
done

if [ $has_deps = false ]; then
    echo "Exiting..."; exit 1
fi

# Bootstrap dirs
mkdir -p ~/me
mkdir -p ~/.config/tmux

# Get dotfiles
url="https://raw.githubusercontent.com/danbergelt/dotfiles/main"
curl -s "$url/.bash_profile" > ~/.bash_profile
curl -s "$url/.vim/vimrc" > ~/.vim/vimrc
curl -s "$url/.config/tmux/tmux.conf" > ~/.config/tmux/tmux.conf

# Bootstrap vim
curl -sfLo ~/.vim/autoload/plug.vim --create-dirs \
    https://raw.githubusercontent.com/junegunn/vim-plug/master/plug.vim
vim -N -E -s -u "~/.vim/vimrc" +PlugInstall +qall
